NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_company_assistant
POSTGRES_DB=ai_company_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Frontend. Local dev normally uses http://localhost:3000.
# Docker Compose publishes the API on http://localhost:38082.
VITE_API_BASE_URL=http://localhost:3000

# Aliyun OSS stores original files. The database stores file metadata only.
ALI_OSS_REGION=oss-cn-shanghai
ALI_OSS_BUCKET=your-oss-bucket
ALI_OSS_ACCESS_KEY_ID=
ALI_OSS_ACCESS_KEY_SECRET=
ALI_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com

CHAT_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

EMBEDDING_PROVIDER=aliyun
ALI_EMBEDDING_API_KEY=
ALI_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALI_EMBEDDING_MODEL=text-embedding-v4
ZHIPU_API_KEY=
ZHIPU_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_EMBEDDING_MODEL=embedding-3
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
